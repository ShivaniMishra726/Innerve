# TruthGuard — Environment Variables
#
# Copy this file to .env.local and fill in your API keys.
# None of these variables are required for the app to run —
# they enable optional cloud-enhanced analysis when set.

# ---------------------------------------------------------------------------
# HuggingFace Inference API
# Used for NLP-based zero-shot misinformation classification.
# The model (facebook/bart-large-mnli) is called when local confidence < 70 %.
# Get your free key at: https://huggingface.co/settings/tokens
# ---------------------------------------------------------------------------
HUGGINGFACE_API_KEY=

# ---------------------------------------------------------------------------
# Google Fact Check Tools API
# Used to enrich low-confidence results with verified fact-check records.
# Enable the "Fact Check Tools API" in Google Cloud Console, then create
# an API key at: https://console.cloud.google.com/apis/credentials
# ---------------------------------------------------------------------------
GOOGLE_FACT_CHECK_API_KEY=
